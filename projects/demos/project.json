{
  "name": "demos",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "projectType": "application",
  "tags": ["scope:demos"],
  "sourceRoot": "projects/demos/src",
  "targets": {
    "build": {
      "executor": "@angular-devkit/build-angular:application",
      "outputs": ["{options.outputPath}"],
      "options": {
        "outputPath": "dist/demos",
        "index": "projects/demos/index.html",
        "browser": "projects/demos/src/main.ts",
        "server": "projects/demos/src/main.server.ts",
        "tsConfig": "projects/demos/tsconfig.app.json",
        "inlineStyleLanguage": "scss",
        "assets": [],
        "styles": ["projects/demos/src/styles.scss"],
        "scripts": [],
        "outputMode": "server",
        "ssr": {
          "entry": "projects/demos/src/server.ts"
        }
      },
      "configurations": {
        "production": {
          "budgets": [
            {
              "type": "initial",
              "maximumWarning": "500kb",
              "maximumError": "2mb"
            }
          ],
          "outputHashing": "none"
        },
        "development": {
          "optimization": false,
          "extractLicenses": false,
          "sourceMap": true
        }
      },
      "defaultConfiguration": "production"
    },
    "buildElements": {
      "executor": "@angular-devkit/build-angular:application",
      "outputs": ["{options.outputPath}"],
      "options": {
        "outputPath": "projects/docs/public/demos",
        "browser": "projects/demos/src/main.elements.ts",
        "tsConfig": "projects/demos/tsconfig.app.json",
        "inlineStyleLanguage": "scss",
        "assets": [],
        "styles": ["projects/demos/src/styles.scss"],
        "scripts": [],
        "index": false
      },
      "configurations": {
        "production": {
          "optimization": true,
          "outputHashing": "none"
        },
        "development": {
          "optimization": false,
          "extractLicenses": false,
          "sourceMap": true
        }
      }
    },
    "serve": {
      "executor": "@angular-devkit/build-angular:dev-server",
      "configurations": {
        "production": {
          "buildTarget": "demos:build:production"
        },
        "development": {
          "buildTarget": "demos:build:development"
        }
      },
      "defaultConfiguration": "development"
    }
  }
}

